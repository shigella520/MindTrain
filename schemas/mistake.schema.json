{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mistake.schema.json",
  "title": "Mistake Event",
  "type": "object",
  "required": ["schemaVersion", "id", "attemptId", "sessionId", "questionId", "questionVersion", "topicIds", "selectedOptionIds", "correctOptionIds", "recordedAt", "resolved"],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "attemptId": {"type": "string", "minLength": 1},
    "sessionId": {"type": "string", "minLength": 1},
    "questionId": {"type": "string", "minLength": 1},
    "questionVersion": {"type": "integer", "minimum": 1},
    "topicIds": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "selectedOptionIds": {"type": "array", "minItems": 1, "items": {"enum": ["A", "B", "C", "D"]}},
    "correctOptionIds": {"type": "array", "minItems": 1, "items": {"enum": ["A", "B", "C", "D"]}},
    "recordedAt": {"type": "string", "format": "date-time"},
    "resolved": {"type": "boolean"}
  },
  "additionalProperties": false
}
