{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "session.schema.json",
  "title": "Training Session",
  "type": "object",
  "required": ["schemaVersion", "id", "status", "target", "completedMainQuestions", "followUpCount", "questionChain", "startedAt"],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "status": {"enum": ["active", "completed", "abandoned"]},
    "target": {
      "type": "object",
      "required": ["questionCount", "questionTypes", "scope"],
      "properties": {
        "questionCount": {"type": "integer", "minimum": 1},
        "questionTypes": {"type": "array", "minItems": 1, "items": {"enum": ["single_choice", "multiple_choice"]}},
        "scope": {"type": "string"}
      },
      "additionalProperties": false
    },
    "completedMainQuestions": {"type": "integer", "minimum": 0},
    "followUpCount": {"type": "integer", "minimum": 0},
    "questionChain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attemptId", "questionId", "attemptType", "correct"],
        "properties": {
          "attemptId": {"type": "string"},
          "questionId": {"type": "string"},
          "attemptType": {"enum": ["main", "follow_up"]},
          "parentAttemptId": {"type": ["string", "null"]},
          "correct": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "startedAt": {"type": "string", "format": "date-time"},
    "endedAt": {"type": ["string", "null"], "format": "date-time"},
    "summary": {
      "type": ["object", "null"],
      "properties": {
        "totalAttempts": {"type": "integer", "minimum": 0},
        "correctAttempts": {"type": "integer", "minimum": 0},
        "accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "singleChoice": {"type": "object"},
        "multipleChoice": {"type": "object"},
        "topicPerformance": {"type": "object"},
        "wrongQuestionIds": {"type": "array", "items": {"type": "string"}},
        "weakTopicIds": {"type": "array", "items": {"type": "string"}},
        "nextReviewAt": {"type": ["string", "null"], "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
