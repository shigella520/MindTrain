{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "attempt.schema.json",
  "title": "Choice Question Attempt",
  "type": "object",
  "required": [
    "schemaVersion", "id", "sessionId", "questionId", "questionVersion", "questionType", "attemptType",
    "topicIds", "rawAnswer", "selectedOptionIds", "correctOptionIds", "correct", "score", "answeredAt"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "sessionId": {"type": "string", "minLength": 1},
    "questionId": {"type": "string", "minLength": 1},
    "questionVersion": {"type": "integer", "minimum": 1},
    "questionType": {"enum": ["single_choice", "multiple_choice"]},
    "attemptType": {"enum": ["main", "follow_up"]},
    "parentAttemptId": {"type": ["string", "null"]},
    "topicIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "rawAnswer": {"type": "string", "minLength": 1},
    "selectedOptionIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["A", "B", "C", "D"]}},
    "correctOptionIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["A", "B", "C", "D"]}},
    "correct": {"type": "boolean"},
    "score": {"enum": [0, 100]},
    "answeredAt": {"type": "string", "format": "date-time"},
    "responseTimeSeconds": {"type": ["integer", "null"], "minimum": 0},
    "model": {"type": ["string", "null"]},
    "promptVersion": {"type": "string"}
  },
  "additionalProperties": false
}
