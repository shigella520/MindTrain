{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "topic.schema.json",
  "title": "Java Backend Interview Taxonomy",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "title", "topics"],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "title": {"type": "string"},
    "topics": {
      "type": "array",
      "minItems": 90,
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "importance", "javaVersions", "keywords", "sourceRefs"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$"},
          "name": {"type": "string", "minLength": 1},
          "parentId": {"type": ["string", "null"]},
          "kind": {"enum": ["domain", "leaf"]},
          "importance": {"type": "integer", "minimum": 1, "maximum": 5},
          "javaVersions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "keywords": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "sourceRefs": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
